# Email (Resend) — sign up at resend.com, add domain, paste API key
RESEND_API_KEY=
# Where enquiry notifications go (your Gmail)
NOTIFY_EMAIL=hello@example.com
# Sender addresses (must be on a domain verified in Resend)
EMAIL_FROM_NOTIFY="Matt Strohm Media <enquiries@mattstrohmmedia.com>"
EMAIL_FROM_REPLY="Matt Strohm Media <hello@mattstrohmmedia.com>"

# Cloudflare Turnstile — free at dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Google Analytics 4 measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Public site URL (no trailing slash) — used for canonical/OG/sitemap
NEXT_PUBLIC_SITE_URL=https://mattstrohmmedia.com

# Booking mode — "form" routes to /contact; "cal" will open Cal.com when wired up later
NEXT_PUBLIC_BOOKING_MODE=form
NEXT_PUBLIC_CAL_URL=
